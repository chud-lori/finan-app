# Copy this to .env and fill in the values before running docker compose

# JWT secret — use a long random string in production
SECRET_TOKEN=changeme_use_a_long_random_string_here

# MongoDB URI (default connects to the mongo service defined in compose)
DB_URI=mongodb://mongo:27017/finan

# URL the browser uses to reach the backend API.
# If running locally: http://localhost:3001
# If deploying to a server: http://your-server-ip:3001  (or your domain)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Google OAuth (get these from Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Used only server-side (legacy — can be set to any value)
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback
FE_URL=http://localhost:3000
# Used client-side by the frontend popup OAuth flow — must match GOOGLE_CLIENT_ID
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id

# Email / Password reset (via Resend — https://resend.com)
# 1. Sign up at resend.com and add your domain
# 2. Create an API key under API Keys
# 3. Set FROM_EMAIL to a verified address on your domain (e.g. noreply@yourdomain.com)
RESEND_API_KEY=re_your_api_key_here
FROM_EMAIL=noreply@yourdomain.com

# Email transaction import (optional — the feature is disabled when these are unset)
# Users forward BCA / Bank Jago notification emails to EMAIL_INGEST_ADDRESS with a
# per-user plus tag (finan+<token>@domain); the backend polls that mailbox over IMAP.
# Use an app password for EMAIL_INGEST_IMAP_PASS, never the real account password.
EMAIL_INGEST_ADDRESS=
EMAIL_INGEST_IMAP_HOST=
EMAIL_INGEST_IMAP_PORT=993
EMAIL_INGEST_IMAP_USER=
EMAIL_INGEST_IMAP_PASS=
EMAIL_INGEST_POLL_MS=300000

# Gmail connector variant (optional): users click "Connect Gmail" and grant
# gmail.readonly; only BCA / Bank Jago notification emails are read.
# Requires GOOGLE_CLIENT_ID/SECRET above, plus:
# 1. Enable the Gmail API in Google Cloud Console
# 2. Add the gmail.readonly scope to the OAuth consent screen
# 3. Register EMAIL_INGEST_GMAIL_REDIRECT_URL as an authorized redirect URI
# 4. While the app is unverified: add each user's Gmail as a test user (max 100;
#    refresh tokens expire every 7 days — users just click Reconnect)
# Generate the encryption key with: openssl rand -hex 32
EMAIL_INGEST_ENCRYPTION_KEY=
EMAIL_INGEST_GMAIL_REDIRECT_URL=http://localhost:3001/api/email-ingest/gmail/callback
